---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import { Image } from "astro:assets";
import Navbar from "../../components/Navbar.astro";
import { products } from "../../data/design";

export function getStaticPaths() {
  return products.map((p) => ({
    params: { slug: p.slug },
  }));
}

const { slug } = Astro.params;
const product = products.find((p) => p.slug === slug);
---

<Layout>
  <header class="relative flex flex-col items-center justify-center text-center py-60">
    <Navbar />
    <div class="header-bg absolute z-[-1]">
      <Image src={product.image} alt={product.name} width={1600} priority />
    </div>
    <h1 class="text-6xl font-thin mb-4">{product.name}</h1>
    <h2 class="text-lg text-gray-600 uppercase">{product.tag}</h2>
  </header>

  <main class="bg-gray-100 h-full py-30 border-b border-gray-200">
    <p
      class="text-lg md:text-2xl text-gray-600 mx-10 lg:mx-auto lg:max-w-[960px] text-center mb-30"
    >
      {product.description}
    </p>
    <div class="swiper">
      <div class="swiper-wrapper">
        {
          product.gallery.map((item) => (
            <div class="swiper-slide flex justify-center items-center w-[75vw] max-w-[800px] rounded-2xl overflow-hidden">
              <Image
                src={item}
                alt={product.name}
                width={1200}
                class="w-full h-160 object-cover rounded-2xl"
              />
            </div>
          ))
        }
      </div>
      <div class="swiper-pagination"></div>
    </div>
    <div class="custom-swiper-nav flex justify-center gap-4 mt-6">
      <button
        id="custom-prev"
        class="rounded-full bg-white shadow px-4 py-2 text-gray-700 hover:bg-gray-200 transition"
        disabled
      >
        &larr;
      </button>
      <button
        id="custom-next"
        class="rounded-full bg-white shadow px-4 py-2 text-gray-700 hover:bg-gray-200 transition"
        disabled
      >
        &rarr;
      </button>
    </div>

    <!-- 3d model -->
    <!-- <div
      class="bg-white flex justify-center items-center w-[75vw] max-w-[1200px] mx-auto my-32 rounded-2xl overflow-hidden"
    >
      testy
    </div> -->
  </main>

  <Footer />
</Layout>
<style>
  header {
    height: 100%;
    min-height: 50vh;
  }

  .header-bg img {
    object-position: center;
  }
  .header-bg::after {
    content: "";
    opacity: 0.8;
    position: absolute;
    width: 100%;
    height: 100%;
    left: 0;
    top: 0;
    background: #fff;
  }
  .swiper {
    width: 100%;
    padding-bottom: 40px;
  }
  .swiper-wrapper {
    align-items: center;
  }
  .swiper-slide {
    transition: transform 0.3s;
  }
  .swiper-slide:last-child {
    margin-right: 0;
  }
  .swiper-slide {
    opacity: 0.6;
    scale: 0.95;
  }
  .swiper-slide.swiper-slide-active {
    opacity: 1;
    scale: 1;
  }
  .custom-swiper-nav button {
    font-size: 1.5rem;
    border: none;
    outline: none;
    cursor: pointer;
  }
  .custom-swiper-nav button:active {
    background: #e5e7eb;
  }
  .custom-swiper-nav button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
<script>
  import Swiper from "swiper";
  import "swiper/css";

  const swiper = new Swiper(".swiper", {
    direction: "horizontal",
    slidesPerView: "auto",
    centeredSlides: true,
    spaceBetween: 32,
    pagination: {
      el: ".swiper-pagination",
    },
  });

  const prevBtn = document.getElementById("custom-prev");
  const nextBtn = document.getElementById("custom-next");

  function updateNavButtons() {
    prevBtn.disabled = swiper.activeIndex === 0;
    nextBtn.disabled = swiper.activeIndex === swiper.slides.length - 1;
  }

  prevBtn.addEventListener("click", () => {
    swiper.slidePrev();
  });
  nextBtn.addEventListener("click", () => {
    swiper.slideNext();
  });

  swiper.on("slideChange", updateNavButtons);
  // Initial state
  updateNavButtons();
</script>
