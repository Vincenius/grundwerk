---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import { Image } from "astro:assets";
import header from "../assets/abstract-bg.jpg";
import laptop from "../assets/laptop.jpg";
---

<Layout>
  <header class="relative">
    <Navbar />
    <div class="header-bg absolute z-[-1]">
      <Image src={header} alt="abstract background" width={1200} priority />
    </div>
    <div class="container mx-auto py-32 px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 items-center gap-8">
        <div class="max-w-lg">
          <h2 class="text-4xl font-thin text-gray-900 sm:text-4xl underline uppercase">
            About Us
          </h2>
          <p class="mt-8 text-gray-600 text-lg">
            grundwerk is a design studio focused on creating smart,
            stylish essentials for modern life. We blend product strategy,
            industrial design, and visual storytelling to deliver products that are
            both beautiful and functional.
          </p>
          <p class="mt-4 text-gray-600 text-lg">
            Our team specializes in crafting physical products that prioritize
            performance, usability, and contemporary aesthetics. From early concepts
            to refined final details, we believe great design should elevate every
            interaction. Let's build something remarkable together.
          </p>
          <div class="mt-8">
            <a
              href="mailto:hello@grundwerk.design"
              class="text-indigo-600 hover:text-indigo-500 font-medium"
            >
              Contact us
              <span class="ml-2">&#8594;</span></a
            >
          </div>
        </div>
        <div class="mt-12 md:mt-0">
          <Image src={laptop} alt="colorful laptop" width={1200} priority class="object-cover rounded-lg shadow-md" />
        </div>
      </div>
    </div>
  </header>

  <Footer />
</Layout>
<style>
  header {
    height: 100%;
    min-height: 90vh;
  }
  .header-bg::after {
    content: "";
    opacity: 0.8;
    position: absolute;
    width: 100%;
    height: 100%;
    left: 0;
    top: 0;
    background: #fff;
  }
</style>
