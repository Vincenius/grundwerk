---
const videoSrc = "/videos/headphone-preview.mp4"; // Change to your video path
---

<section class="relative">
  <div
    class="video-section relative inset-0 w-screen h-screen overflow-hidden"
    id="product-video-section"
  >
    <div
      id="video-wrapper"
      class="relative w-screen h-screen overflow-hidden"
      style="transform-origin: center center; border-radius: 0;"
    >
      <video
        id="product-video"
        src={videoSrc}
        class="w-full h-full object-cover"
        style="border-radius: 0;"
        muted
        playsinline
        loop
        preload="auto"></video>
      <div
        class="overlay absolute inset-0 bg-black/70 flex items-center justify-center"
        id="video-overlay"
      >
      </div>
    </div>
  </div>
  <div class="absolute inset-0 pt-[50vh] px-[3em]">
    <h1 class="text-white text-6xl text-center font-thin">
      Design Case Studies
    </h1>
    <h2 class="text-white text-3xl mt-4 text-center font-thin opacity-60">
      Conceptual explorations in product design. See what we can create.
    </h2>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener("DOMContentLoaded", () => {
    const videoSection = document.getElementById("product-video-section");
    const video = document.getElementById("product-video");
    const videoWrapper = document.getElementById("video-wrapper");
    const overlay = document.getElementById("video-overlay");

    // Unified scrubbed timeline with two phases
    const scrollTl = gsap.timeline({
      scrollTrigger: {
        trigger: videoSection,
        start: "top top",
        end: "+=600px",
        scrub: true,
        pin: true,
        pinSpacing: true,
        onEnter: () => video.play(),
        // onLeaveBack: () => video.pause(),
      },
    });

    // Phase 1: wait, then fade overlay out
    scrollTl.to(overlay, { opacity: 0.2, duration: 0.4 }, 0.5);

    // Phase 2: shrink + round video wrapper only after overlay is gone
    scrollTl.to(
      videoWrapper,
      {
        scale: 0.8,
        borderRadius: "48px",
        ease: "power2.out",
        duration: 0.5,
      },
      0.7 // starts right after overlay fade completes
    );
  });
</script>
