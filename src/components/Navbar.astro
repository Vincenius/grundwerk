---
import Logo from "../assets/logo.png";
import { Image } from "astro:assets";
let menuOpen = false;
function toggleMenu() {
  menuOpen = !menuOpen;
}

// Menu items array
const menuItems = [
  { href: "/products", label: "Product Design" },
  { href: "/web", label: "Web Development" },
  { href: "/about", label: "About us" },
];
---

<nav
  class="absolute top-0 z-30 mx-auto w-full max-w-screen-md border border-gray-100 bg-white/80 py-3 inset-shadow-sm/20 md:top-6 md:rounded-3xl lg:max-w-screen-lg"
>
  <div class="px-4">
    <div class="flex items-center justify-between">
      <div class="flex shrink-0">
        <a aria-current="page" class="flex items-center" href="/">
          <Image
            src={Logo}
            alt="grundwerk logo"
            class="h-8 w-auto"
            width={64}
            height={64}
            priority
          />
          <p class="sr-only">grundwerk</p>
        </a>
      </div>

      {/* Center menu: hidden on small screens, visible on md+ */}
      <div class="hidden md:flex md:items-center md:justify-center md:gap-5">
        {
          menuItems.map(item => (
            <a
              class="inline-block rounded-lg px-2 py-1 text-sm font-medium text-gray-900 transition-all duration-200 hover:bg-gray-100 hover:text-gray-900"
              href={item.href}
            >{item.label}</a>
          ))
        }
      </div>
      <div class="flex items-center justify-end gap-3">
        <a
          class="inline-flex items-center justify-center rounded-xl bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm transition-all duration-150 hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600"
          href="mailto:hello@grundwerk.design">Contact</a
        >

        {/* Burger menu button for small screens */}
        <button
          class="md:hidden inline-flex items-center justify-center p-2 ml-4 rounded-lg text-gray-900 hover:bg-gray-100 focus:outline-none"
          aria-label={menuOpen ? "Close menu" : "Open menu"}
          id="burger-menu"
        >
          {
            menuOpen ? (
              // "X" icon
              <svg
                class="h-6 w-6"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M6 18L18 6M6 6l12 12"
                />
              </svg>
            ) : (
              // Burger icon
              <svg
                class="h-6 w-6"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4 6h16M4 12h16M4 18h16"
                />
              </svg>
            )
          }
        </button>
      </div>
    </div>
    {/* Dropdown menu for small screens */}
    <div
      id="navbar-menu"
      class={menuOpen
        ? "block !md:hidden absolute left-0 right-0 mt-2 z-40 bg-white rounded-xl shadow-lg border border-gray-100 p-4 w-[200px] right-5"
        : "hidden !md:hidden absolute left-0 right-0 mt-2 z-40 bg-white rounded-xl shadow-lg border border-gray-100 p-4 w-[200px] right-5"}
      style="top:100%; left: 99%; transform: translateX(-100%);"
    >
      <ul class="flex flex-col gap-2">
        {
          menuItems.map(item => (
            <li>
              <a
                class="rounded-lg px-4 py-2 my-2 text-sm font-medium text-gray-900 hover:bg-gray-100"
                href={item.href}
                onClick={() => (menuOpen = false)}
              >{item.label}</a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</nav>
<script>
  // Minimal client-side interactivity for burger menu
  let menuOpen = false;
  const burgerBtn = document.querySelector("#burger-menu");
  const navbarMenu = document.querySelector("#navbar-menu");
  burgerBtn.addEventListener("click", () => {
    menuOpen = !menuOpen;
    navbarMenu.style.display = menuOpen ? "block" : "none";
    // Toggle icon
    burgerBtn.setAttribute("aria-label", menuOpen ? "Close menu" : "Open menu");
    burgerBtn.innerHTML = menuOpen
      ? `<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>`
      : `<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path></svg>`;
  });
</script>
