---
const { product } = Astro.props;
import { Image } from "astro:assets";
---

<a
  href={`/design/${product.slug}`}
  class={`block mx-auto w-full`}
  data-product-card
>
  <div class="bg-white shadow-lg border border-gray-100 rounded-xl overflow-hidden transition-transform transition-shadow duration-200 hover:scale-[1.03] hover:shadow-xl">
    {product.image && (
      <div class="p-3 relative">
        <Image
          src={product.image}
          alt={product.name}
          class="w-full h-full object-cover rounded-lg"
          width={1200}
        />
        <div class="absolute inset-3 rounded-lg bg-black opacity-5"></div>
      </div>
    )}
    <div class="px-6 pb-4">
      <!-- <span class="inline-block px-3 py-1 bg-gray-100 text-gray-600 text-xs font-semibold rounded-full mb-3">Case Study</span> -->
      <h3 class="text-2xl font-bold text-black mb-2">{product.name}</h3>
      <span class="text-gray-400 uppercase text-md block uppercase">{product.tag}</span>
    </div>
  </div>
</a>
