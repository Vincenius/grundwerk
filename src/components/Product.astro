---
const { product } = Astro.props;
import { Image } from "astro:assets";
---

<a
  href={`/products/${product.slug}`}
  class={`block mx-auto w-full`}
  data-product-card
>
  <div class="bg-white shadow-lg border border-gray-100 rounded-xl overflow-hidden transition-transform transition-shadow duration-200 hover:scale-[1.03] hover:shadow-xl">
    {product.image && <Image
      src={product.image}
      alt={product.name}
      class="w-full h-96 object-cover"
      width={1200}
    />}
    <div class="px-6 py-4">
      <span class="inline-block px-3 py-1 bg-gray-100 text-gray-600 text-xs font-semibold rounded-full mb-3">Case Study</span>
      <span class="text-gray-400 uppercase text-md block mb-2 uppercase">{product.tag}</span>
      <h3 class="text-2xl font-bold text-black">{product.name}</h3>
    </div>
  </div>
</a>
