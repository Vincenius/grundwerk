---
const { product } = Astro.props;
import { Image } from "astro:assets";
---

{
  product.url ? (
    <a
      href={product.url}
      target="_blank"
      rel="noopener noreferrer"
      class={`block mx-auto w-full`}
      data-product-card
    >
      <div class="bg-white shadow-lg border border-gray-100 overflow-hidden transition-transform transition-shadow rounded-b-xl duration-200 hover:scale-[1.03] hover:shadow-xl">
        <div class="h-[30px] w-full bg-[#e8e8e8] flex items-center rounded-t">
          <div class="w-[12px] h-[12px] rounded-[12px] ml-[8px] mx-[4px] bg-[#FF4F4D]" />
          <div class="w-[12px] h-[12px] rounded-[12px] mx-[4px] bg-[#ffbb00]" />
          <div class="w-[12px] h-[12px] rounded-[12px] mx-[4px] bg-[#00CE15]" />
        </div>
        {product.image && (
          <Image
            src={product.image}
            alt={product.name}
            class="w-full h-60 sm:h-84 object-cover"
            width={1200}
          />
        )}
        <div class="px-6 py-4">
          <span class="text-gray-400 uppercase text-md block mb-2 uppercase">
            {product.tag}
          </span>
          <h3 class="text-2xl font-bold text-black">{product.name}</h3>
        </div>
      </div>
    </a>
  ) : (
    <div class="block mx-auto w-full" data-product-card>
      <div class="bg-white shadow-lg border border-gray-100 rounded-xl overflow-hidden rounded-b-xl">
        <div class="h-[30px] w-full bg-[#e8e8e8] flex items-center rounded-t">
          <div class="w-[12px] h-[12px] rounded-[12px] ml-[8px] mx-[4px] bg-[#FF4F4D]" />
          <div class="w-[12px] h-[12px] rounded-[12px] mx-[4px] bg-[#ffbb00]" />
          <div class="w-[12px] h-[12px] rounded-[12px] mx-[4px] bg-[#00CE15]" />
        </div>
        {product.image && (
          <Image
            src={product.image}
            alt={product.name}
            class="w-full h-84 object-cover"
            width={1200}
          />
        )}
        <div class="px-6 py-4">
          <span class="text-gray-400 uppercase text-md block mb-2 uppercase">
            {product.tag}
          </span>
          <h3 class="text-2xl font-bold text-gray-500">
            {product.name} (discontinued)
          </h3>
        </div>
      </div>
    </div>
  )
}
